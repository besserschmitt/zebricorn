{
	"name": "Python 3",
	"image": "mcr.microsoft.com/devcontainers/python:3.11",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylint"
			]
		}
	},
	"postCreateCommand": "pip install -r requirements.txt"
}